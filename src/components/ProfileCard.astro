---
import Image from "astro/components/Image.astro"
import Skills from "./Skills.astro"
import Skill from "./Skill.astro"

const skills = [
  "HTML / CSS", "JavaScript", "TypeScript", "React", "Svelte", "Node.js",
  "Kotlin", "Jetpack Compose",
  "Zig"
]
---

<article class="p-4 border border-zinc-300 rounded-lg flex flex-col gap-y-4 shadow-lg dark:bg-zinc-800 dark:border-zinc-600">
  <header class="grid grid-cols-[80px_minmax(0,_1fr)] grid-rows-1 gap-x-4 items-center">
    <Image class="aspect-square w-32 rounded-full row-span-2" src={`${import.meta.env.BASE_URL}/profile.jpg`} alt="" width="100" height="100" />
    <div>
      <h2 class="text-3xl font-bold">うえき</h2>
      <span class="text-zinc-800 dark:text-white/70">(Rafael ヤスヒデ 須藤)</span>
    </div>
  </header>
  <Skills>
    {skills.map(skill => <Skill>{skill}</Skill>)}
  </Skills>
  <main>
    <span>プログラミングと、音楽と、デザインと、モノが好き。</span>
    <slot />
  </main>
</article>